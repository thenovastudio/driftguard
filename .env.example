DATABASE_URL=postgresql://postgres:postgres@localhost:5432/driftguard
REDIS_URL=redis://localhost:6379

# Service API Keys
STRIPE_API_KEY=
VERCEL_API_TOKEN=
SENDGRID_API_KEY=

# Slack
SLACK_WEBHOOK_URL=

# Polling interval (cron expression, default: every 6 hours)
POLL_INTERVAL=0 */6 * * *

# Server
PORT=3000
NODE_ENV=development
